# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenHere

# How often to check stock, in seconds. Floored at 20s in code so it can't
# be set low enough to hammer Lazada's servers.
POLL_INTERVAL_SECONDS=30

# Where subscriber lists + stock state are persisted
DB_FILE=./data.json

# Required for Playwright's Chromium fallback to work on Render specifically.
# 0 means "install inside node_modules/playwright" instead of the default
# ~/.cache location, which doesn't survive Render's build->runtime handoff.
PLAYWRIGHT_BROWSERS_PATH=0
